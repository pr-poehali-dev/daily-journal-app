{
  "tests": [
    {
      "name": "POST register",
      "method": "POST",
      "path": "/auth/register",
      "body": "{\"email\": \"test@test.com\", \"password\": \"pass123\", \"name\": \"Тест\"}",
      "expectedStatus": 201,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST login",
      "method": "POST",
      "path": "/auth/login",
      "body": "{\"email\": \"test@test.com\", \"password\": \"pass123\"}",
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "GET tasks without token",
      "method": "GET",
      "path": "/tasks",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
